{
  "name": "dept-notes",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:reset": "rm -f prisma/dev.db dev.db && prisma db push"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@monaco-editor/react": "^4.6.0",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "marked": "^14.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
