# SQLite database path
DATABASE_URL="file:./dev.db"

# Fastify server port (dev & prod)
PORT=3001

# Vite dev server port (dev only)
DEV_PORT=5173

# ── User access keys ──────────────────────────────────────────────
# Format: USER_KEY_<username>=<secret-key>
# Each user gets their own isolated memo space.
# Omit all USER_KEY_* lines to run without authentication (local dev only).
#
# Generate a key:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
#
# USER_KEY_alice=replace-with-a-strong-random-key
# USER_KEY_bob=another-strong-random-key
